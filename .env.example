# Variables de entorno para desarrollo local y Cloudflare Pages
# La Cloudflare Function en /functions/api/subscribe.js usa estas variables
# En producción, configúralas en Cloudflare Pages Dashboard → Settings → Environment variables

# Clave API v3 de Brevo (Cuenta → SMTP & API → API Keys)
BREVO_API_KEY=tu_api_key_aqui

# ID de la lista de contactos (Contactos → Listas → click en la lista → el ID en la URL)
BREVO_LIST_ID=3
