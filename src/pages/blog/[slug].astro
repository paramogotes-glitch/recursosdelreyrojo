---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return Promise.all(
    posts.map(async (post) => {
      const { Content } = await post.render();
      return {
        params: { slug: post.slug },
        props: { post, Content },
      };
    })
  );
}

const { post, Content } = Astro.props;
const { title } = post.data;
---

<Layout>
  <article class="article">
    <header>
      <h1>{title}</h1>
    </header>

    <div class="content">
      <Content />
    </div>

    <div class="article-cta">
      <h3>No te pierdas ni un Edicto</h3>
      <p>
        Esto es una muestra de lo que recibes cada mañana. Copywriting, persuasion
        y negocio digital sin humo, directo a tu bandeja.
      </p>
      <a href="/#suscribirse">Suscribirse gratis</a>
    </div>
  </article>
</Layout>
