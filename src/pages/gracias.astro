---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="thanks-page">
    <div>
      <h1>Revisa tu email</h1>
      <p>
        Te hemos enviado un correo de confirmación.
        Haz clic en el enlace que encontrarás dentro para activar tu suscripción
        y empezar a recibir El Edicto Real cada mañana.
      </p>
      <p style="margin-top: 1.5rem; font-size: 0.85rem; color: var(--gris-medio);">
        Si no lo ves, revisa la carpeta de spam o promociones.
      </p>
    </div>
  </div>
</Layout>
